# Web Build Environment Variables

# API server base URL (the Express/Node.js backend)
VITE_API_BASE_URL=http://localhost:3001

# WebSocket URL for real-time events
VITE_WS_URL=ws://localhost:3001/ws

# Optional: Override for production
# VITE_API_BASE_URL=https://api.lobsterai.example.com
# VITE_WS_URL=wss://api.lobsterai.example.com/ws
